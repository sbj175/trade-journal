{
  "permissions": {
    "allow": [
      "Bash(*)",
      "mcp__linear__*",
      "WebSearch",
      "WebFetch(*)"
    ],
    "deny": [
      "mcp__linear__delete*"
    ],
    "ask": []
  },
  "outputStyle": "default",

    "mcpServers": {
    "linear": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.linear.app/sse"]
    }
  }
}
